body{
margin:0;
font-family:'Fredoka',sans-serif;
background:linear-gradient(
180deg,
#ffd6ec,
#ffe9c9,
#d7f4ff
);
min-height:100vh;
display:flex;
justify-content:center;
align-items:center;
}

.container{
width:90%;
max-width:900px;
background:white;
padding:30px;
border-radius:40px;
box-shadow:0 0 25px rgba(0,0,0,0.2);
text-align:center;
}

h1{
color:#ff69b4;
font-size:40px;
}

.subtitle{
color:#777;
font-size:20px;
}

.menuBtn{
width:300px;
padding:20px;
margin:20px;
font-size:25px;
border:none;
border-radius:30px;
cursor:pointer;
background:#ffb6d9;
color:white;
transition:0.3s;
}

.menuBtn:hover{
transform:scale(1.08);
background:#ff85c1;
}

.card{
padding:30px;
background:#fff7fc;
border-radius:30px;
margin-top:30px;
}

.word{
font-size:45px;
color:#ff5fa2;
}

.option{
display:block;
width:80%;
margin:15px auto;
padding:15px;
font-size:22px;
border:none;
border-radius:20px;
background:#dff6ff;
cursor:pointer;
}

.option:hover{
background:#aee7ff;
}

.result{
font-size:25px;
margin-top:20px;
font-weight:bold;
}

.success{
color:green;
}

.fail{
color:red;
}

.nextBtn{
padding:15px 30px;
font-size:20px;
border:none;
border-radius:20px;
background:#ffc96b;
margin-top:20px;
cursor:pointer;
}

.mic{
font-size:70px;
cursor:pointer;
margin-top:20px;
}

.percent{
font-size:40px;
font-weight:bold;
}

.green{
color:green;
}

.red{
color:red;
}
